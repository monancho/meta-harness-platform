{
  "schemaVersion": "1.0.0",
  "contractId": "mh.runResult",
  "format": "json",
  "required": [
    "schemaVersion",
    "runId",
    "adapter",
    "taskId",
    "status",
    "changedFiles",
    "verify",
    "artifacts",
    "startedAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "adapter": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "changedFiles": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "verify": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status", "output"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["passed", "failed"] },
          "output": { "type": "string" }
        }
      }
    },
    "artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "startedAt": { "type": "string", "minLength": 1 }
  }
}
