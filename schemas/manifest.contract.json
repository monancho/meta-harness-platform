{
  "schemaVersion": "1.0.0",
  "contractId": "mh.manifest",
  "format": "json",
  "required": ["schemaVersion", "factoryId", "generator", "source", "answers", "managedFiles"],
  "properties": {
    "schemaVersion": { "type": "number" },
    "factoryId": { "type": "string", "minLength": 1 },
    "generator": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "source": {
      "type": "object",
      "required": ["buildHandoff", "buildHandoffHash"],
      "properties": {
        "buildHandoff": { "type": "string", "minLength": 1 },
        "buildHandoffHash": { "type": "string", "pattern": "^sha256:" }
      }
    },
    "answers": {
      "type": "object",
      "required": ["planningAnswers"],
      "properties": {
        "planningAnswers": { "type": "string", "minLength": 1 },
        "planningBaseline": { "type": "string", "minLength": 1 },
        "planningBaselineHash": { "type": "string", "pattern": "^sha256:" }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "conflictPolicy": { "type": "string", "minLength": 1 }
      }
    },
    "managedFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "ownership", "checksum", "mergeStrategy", "conflictPolicy"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "ownership": { "type": "string", "enum": ["harness", "shared", "target"] },
          "checksum": { "type": "string", "pattern": "^sha256:" },
          "mergeStrategy": { "type": "string", "enum": ["replace-if-unchanged", "managed-blocks", "propose-only"] },
          "conflictPolicy": { "type": "string", "minLength": 1 }
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "ownership", "checksum", "mergeStrategy", "conflictPolicy"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "ownership": { "type": "string", "enum": ["harness", "shared", "target"] },
          "checksum": { "type": "string", "pattern": "^sha256:" },
          "mergeStrategy": { "type": "string", "enum": ["replace-if-unchanged", "managed-blocks", "propose-only"] },
          "conflictPolicy": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
