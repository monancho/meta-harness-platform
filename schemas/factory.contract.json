{
  "schemaVersion": "1.0.0",
  "contractId": "mh.factory",
  "format": "yaml",
  "required": ["schemaVersion", "factory", "generatedFrom", "capabilities"],
  "properties": {
    "schemaVersion": { "type": "number" },
    "factory": {
      "type": "object",
      "required": ["id", "version", "generatedBy", "generatorVersion"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generatedBy": { "type": "string", "minLength": 1 },
        "generatorVersion": { "type": "string", "minLength": 1 }
      }
    },
    "generatedFrom": {
      "type": "object",
      "required": ["buildHandoff", "buildHandoffHash"],
      "properties": {
        "buildHandoff": { "type": "string", "minLength": 1 },
        "buildHandoffHash": { "type": "string", "pattern": "^sha256:" }
      }
    },
    "capabilities": {
      "type": "object",
      "required": ["planning", "bootstrap", "mvpBuild", "localWorktreeRunner"],
      "properties": {
        "planning": { "type": "boolean" },
        "bootstrap": { "type": "boolean" },
        "mvpBuild": { "type": "boolean" },
        "localWorktreeRunner": { "type": "boolean" }
      }
    }
  }
}
