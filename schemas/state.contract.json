{
  "schemaVersion": "1.0.0",
  "contractId": "mh.state",
  "format": "yaml",
  "required": ["schemaVersion", "projectState"],
  "properties": {
    "schemaVersion": { "type": "number" },
    "projectState": {
      "type": "object",
      "required": ["projectId", "phase", "updatedAt"],
      "properties": {
        "projectId": { "type": "string", "minLength": 1 },
        "phase": {
          "type": "string",
          "enum": [
            "planning-scaffolded",
            "planning-frozen",
            "factory-ready",
            "runnable",
            "github-connected",
            "release-ready"
          ]
        },
        "updatedAt": { "type": "string", "minLength": 1 },
        "transitionFrom": {
          "type": "string",
          "enum": [
            "empty",
            "planning-scaffolded",
            "planning-frozen",
            "factory-ready",
            "runnable"
          ]
        },
        "transitionHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "planningBaselineHash": { "type": "string", "pattern": "^sha256:([a-f0-9]{64}|missing)$" },
        "buildHandoffHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "factoryManifestHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "lastRunResultHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "humanApproved": { "type": "boolean" }
      }
    }
  }
}
